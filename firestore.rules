rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuthenticated() && 
        (
          (request.auth.token.email == "jumphorse@nate.com") ||
          (request.auth.token.email == "seokgwan.ms01@gmail.com") ||
          (request.auth.uid == "sfViap2UZ2alO1kzinMETlcLCxv1") ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }
    function hasPermission(menu) {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions[menu] == true;
    }
    function isLeader() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'leader';
    }
    function isPastor() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'pastor';
    }

    // User rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && 
                      (request.resource.data.role == 'member' || request.auth.token.email == 'jumphorse@nate.com' || request.auth.token.email == 'seokgwan.ms01@gmail.com') &&
                      (
                        !('permissions' in request.resource.data) || 
                        (
                          request.resource.data.permissions.survey == false &&
                          request.resource.data.permissions.finance == false &&
                          request.resource.data.permissions.schedule == false &&
                          request.resource.data.permissions.forest == false &&
                          request.resource.data.permissions.attendance == false
                        )
                      );
      allow update: if isOwner(userId) ? 
                      (
                        (!('role' in request.resource.data) || !('role' in resource.data) || request.resource.data.role == resource.data.role || isAdmin()) && 
                        (!('permissions' in request.resource.data) || !('permissions' in resource.data) || request.resource.data.permissions == resource.data.permissions || isAdmin())
                      ) : 
                      isAdmin();
    }

    // Forest rules
    match /forests/{forestId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || hasPermission('forest');
    }

    // Program rules
    match /programs/{programId} {
      allow read: if isAuthenticated();
      allow create, delete: if isAdmin() || isLeader();
      allow update: if isAdmin() || isLeader() || (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['applicants']));
    }

    // Attendance rules
    match /attendance/{attendanceId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (request.resource.data.uid == request.auth.uid || isAdmin() || hasPermission('attendance'));
      allow update, delete: if isAdmin() || hasPermission('attendance');
    }

    // Schedule rules
    match /schedules/{scheduleId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin() || hasPermission('schedule');
    }

    // Forest Post rules
    match /forest_posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.author_uid == request.auth.uid;
      allow update, delete: if isAuthenticated() && (resource.data.author_uid == request.auth.uid || isAdmin());
    }

    // Survey rules
    match /surveys/{surveyId} {
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() && 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['responses']) || isAdmin() || hasPermission('survey'));
      allow write: if isAdmin() || hasPermission('survey');
    }

    // Fee rules
    match /fees/{feeId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin() || hasPermission('finance'));
      allow write: if isAdmin() || hasPermission('finance');
    }

    // Worship rules
    match /worships/{worshipId} {
      allow read: if request.auth != null;
      allow create: if isAuthenticated();
      allow update: if isAdmin() || isLeader() || 
        (request.auth != null && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['view_count']));
      allow delete: if isAdmin() || isLeader();
    }

    // Pastoral Records rules
    match /pastoral_records/{recordId} {
      allow read: if isAuthenticated() && (
        isAdmin() || 
        isPastor() || 
        (isLeader() && resource.data.forest_id == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.forest_id && (!('is_sensitive' in resource.data) || resource.data.is_sensitive == false))
      );
      allow create: if isAuthenticated() && (
        isAdmin() || 
        isPastor() || 
        (isLeader() && request.resource.data.forest_id == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.forest_id)
      );
      allow update, delete: if isAuthenticated() && (isAdmin() || isPastor() || request.auth.uid == resource.data.author_uid);
    }

    // Weekly Settlements rules
    match /weekly_settlements/{settlementId} {
      allow read: if isAuthenticated() && (
        isAdmin() || 
        isPastor() || 
        (isLeader() && resource.data.forest_id == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.forest_id)
      );
      allow create: if isAuthenticated() && (
        isAdmin() || 
        isPastor() || 
        (isLeader() && request.resource.data.forest_id == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.forest_id)
      );
      allow update, delete: if isAdmin() || isPastor();
    }

    // Forest Community Chat rules
    match /forest_chats/{chatId} {
      allow read, create, update: if isAuthenticated();
      allow delete: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
    }

    // Forest Community Story rules
    match /forest_stories/{storyId} {
      allow read, create, update: if isAuthenticated();
      allow delete: if isAuthenticated() && (isAdmin() || (!('userId' in resource.data)) || resource.data.userId == request.auth.uid);
    }

    // Weekly Column rules
    match /weekly_columns/{document=**} {
      allow read, write: if isAuthenticated();
    }

    // Meeting Minutes rules
    match /meeting_minutes/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isLeader();
      
      // Specifically allow any user to read/write under likes and comments
      match /likes/{userId} {
        allow read, write: if isAuthenticated();
      }
      match /comments/{commentId} {
        allow read, write: if isAuthenticated();
      }
    }

    // Meeting Agendas rules
    match /meeting_agendas/{document=**} {
      allow read, write: if isAuthenticated();
    }

    // Kids Care rules
    match /kids_cares/{careId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() || isLeader() || isPastor();
      allow update: if isAuthenticated() && (isAdmin() || isLeader() || isPastor() || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['registrations']));
      allow delete: if isAdmin() || isLeader() || isPastor();
    }

    // Kids Applications rules
    match /kids_applications/{appId} {
      allow read: if isAuthenticated() && (
        isAdmin() || isLeader() || isPastor() ||
        resource.data.parent_id == request.auth.uid
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        isAdmin() || isLeader() || isPastor() ||
        resource.data.parent_id == request.auth.uid
      );
      allow delete: if isAdmin() || isLeader() || isPastor() ||
        resource.data.parent_id == request.auth.uid;
    }

    // Family News rules
    match /family_news/{newsId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin() || isLeader() || isPastor();
    }
  }
}
